# Copy this to .env.local and fill in values

# Neon PostgreSQL — get from https://neon.tech dashboard
# Add ?connect_timeout=10 to handle Neon's idle connection termination (E57P01)
DATABASE_URL=postgresql://user:password@host/scrutinder?sslmode=require&connect_timeout=10

# WebAuthn — must match the origin of the app
# Dev: localhost / http://localhost:3000
# Prod: your domain / https://scrutinder.fr
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Optional — used for absolute URLs in server components
NEXT_PUBLIC_BASE_URL=http://localhost:3000
